<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:styles="clr-namespace:ReviewScope.App.Styles">
<BooleanToVisibilityConverter x:Key="BoolVis"/>
<styles:ActiveToolButtonConverter x:Key="ActiveToolButtonConverter"/>

        <Style x:Key="BrowserIconPathStyle" TargetType="Path">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="{StaticResource MutedForeground}"/>
            <Setter Property="StrokeThickness" Value="1.45"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Data" Value="M4,2.5 H10 L13,5.5 V13.5 H4 Z M10,2.5 V5.5 H13"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IconKind}" Value="project">
                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Data" Value="M2.5,4.5 H6 L7.4,6 H13.5 V12.5 H2.5 Z M4.5,2.5 H9.5 V4.5 H4.5 Z"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="folder">
                    <Setter Property="Stroke" Value="{StaticResource SubtleForeground}"/>
                    <Setter Property="Data" Value="M2.5,5 H6 L7.4,6.5 H13.5 V12.5 H2.5 Z"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="solution">
                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Data" Value="M3,3.5 H7 V7.5 H3 Z M9,3.5 H13 V7.5 H9 Z M3,9 H7 V13 H3 Z M9,9 H13 V13 H9 Z"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="project-file">
                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Data" Value="M3,4 H7 V8 H3 Z M9,4 H13 V8 H9 Z M5,8 V11 H11 M8,11 V13.5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="csharp">
                    <Setter Property="Stroke" Value="#4F7DD9"/>
                    <Setter Property="Data" Value="M4,2.5 H10 L13,5.5 V13.5 H4 Z M10,2.5 V5.5 H13 M7.4,8 L6,9.3 L7.4,10.6 M10.6,8 L12,9.3 L10.6,10.6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="xaml">
                    <Setter Property="Stroke" Value="#8B5CF6"/>
                    <Setter Property="Data" Value="M4,2.5 H10 L13,5.5 V13.5 H4 Z M10,2.5 V5.5 H13 M8,7.7 L6.5,9.5 L8,11.3 M10,7.7 L11.5,9.5 L10,11.3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="markdown">
                    <Setter Property="Stroke" Value="#0F766E"/>
                    <Setter Property="Data" Value="M3,4 H13 V12 H3 Z M5,10 V6.5 L7.3,8.9 L9.6,6.5 V10 M11.4,6.5 V10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="json">
                    <Setter Property="Stroke" Value="#B7791F"/>
                    <Setter Property="Data" Value="M4,2.5 H10 L13,5.5 V13.5 H4 Z M10,2.5 V5.5 H13 M7.2,7.8 C6.3,7.8 6.2,8.6 6.2,9.1 C6.2,9.8 5.7,10 5.1,10 M7.2,12.2 C6.3,12.2 6.2,11.4 6.2,10.9 C6.2,10.2 5.7,10 5.1,10 M10.8,7.8 C11.7,7.8 11.8,8.6 11.8,9.1 C11.8,9.8 12.3,10 12.9,10 M10.8,12.2 C11.7,12.2 11.8,11.4 11.8,10.9 C11.8,10.2 12.3,10 12.9,10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="xml">
                    <Setter Property="Stroke" Value="#B7791F"/>
                    <Setter Property="Data" Value="M4,2.5 H10 L13,5.5 V13.5 H4 Z M10,2.5 V5.5 H13 M7.3,8 L5.9,9.5 L7.3,11 M10.7,8 L12.1,9.5 L10.7,11"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="image">
                    <Setter Property="Stroke" Value="#C07AB8"/>
                    <Setter Property="Data" Value="M3,4 H13 V12 H3 Z M5,10 L7,8 L8.8,9.8 L10,8.7 L12,10.8 M10.8,6.2 H10.9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="class">
                    <Setter Property="Stroke" Value="#4F7DD9"/>
                    <Setter Property="Data" Value="M3.5,3.5 H12.5 V12.5 H3.5 Z M5.5,6 H10.5 M5.5,8 H10.5 M5.5,10 H8.5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="interface">
                    <Setter Property="Stroke" Value="#0F766E"/>
                    <Setter Property="Data" Value="M5,4.5 H11 M5,8 H11 M5,11.5 H11 M3,4.5 H3.1 M3,8 H3.1 M3,11.5 H3.1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="record">
                    <Setter Property="Stroke" Value="#4F7DD9"/>
                    <Setter Property="Data" Value="M3.5,4.5 H12.5 V11.5 H3.5 Z M5.5,6.5 H10.5 M5.5,9.5 H8.5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="struct">
                    <Setter Property="Stroke" Value="#4F7DD9"/>
                    <Setter Property="Data" Value="M4,4 H7 V7 H4 Z M9,4 H12 V7 H9 Z M4,9 H7 V12 H4 Z M9,9 H12 V12 H9 Z"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="enum">
                    <Setter Property="Stroke" Value="#B7791F"/>
                    <Setter Property="Data" Value="M4,4.5 H5 M7,4.5 H12 M4,8 H5 M7,8 H12 M4,11.5 H5 M7,11.5 H12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="method">
                    <Setter Property="Stroke" Value="#23A26D"/>
                    <Setter Property="Data" Value="M8,2.8 C5.1,2.8 2.8,5.1 2.8,8 C2.8,10.9 5.1,13.2 8,13.2 C10.9,13.2 13.2,10.9 13.2,8 C13.2,5.1 10.9,2.8 8,2.8 Z M8,5.2 V8 L10.2,10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="constructor">
                    <Setter Property="Stroke" Value="#23A26D"/>
                    <Setter Property="Data" Value="M5,5.5 C5.8,4.2 7.5,3.6 9,4.2 M11.2,6.3 C12.1,8.1 11.5,10.3 9.7,11.4 C7.7,12.6 5.2,12 4,10 C2.9,8.3 3.2,6.1 4.6,4.8 M8.9,2.7 L9.1,4.4 L7.5,4.6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="property">
                    <Setter Property="Stroke" Value="#8B5CF6"/>
                    <Setter Property="Data" Value="M5,3.5 H11 V12.5 H5 Z M7,6.2 H9 M7,8.4 H9 M7,10.6 H9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="field">
                    <Setter Property="Stroke" Value="#8B5CF6"/>
                    <Setter Property="Data" Value="M4,5 H12 V11 H4 Z M6,7 H10 M6,9 H10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="symbol">
                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Data" Value="M8,3 L12.3,5.5 V10.5 L8,13 L3.7,10.5 V5.5 Z"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="empty">
                    <Setter Property="Stroke" Value="{StaticResource MutedForeground}"/>
                    <Setter Property="Data" Value="M5,5 L11,11 M11,5 L5,11"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="note">
                    <Setter Property="Stroke" Value="#D49A4A"/>
                    <Setter Property="Data" Value="M4,3.5 H12 V10 L9.5,12.5 H4 Z M9.5,12.5 V10 H12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="text">
                    <Setter Property="Stroke" Value="#1F2933"/>
                    <Setter Property="Data" Value="M4,4.5 H12 M8,4.5 V12 M5.5,12 H10.5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="shape">
                    <Setter Property="Stroke" Value="#4F7DD9"/>
                    <Setter Property="Data" Value="M8,3 L13,8 L8,13 L3,8 Z"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="database">
                    <Setter Property="Stroke" Value="#0F766E"/>
                    <Setter Property="Data" Value="M4,5 C4,3.9 5.8,3 8,3 C10.2,3 12,3.9 12,5 C12,6.1 10.2,7 8,7 C5.8,7 4,6.1 4,5 Z M4,5 V11 C4,12.1 5.8,13 8,13 C10.2,13 12,12.1 12,11 V5 M4,8 C4,9.1 5.8,10 8,10 C10.2,10 12,9.1 12,8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="risk">
                    <Setter Property="Stroke" Value="#E05252"/>
                    <Setter Property="Data" Value="M8,3 L13,12.5 H3 Z M8,6.5 V9 M8,11 H8.1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="container">
                    <Setter Property="Stroke" Value="#64748B"/>
                    <Setter Property="Data" Value="M3,4 H13 V12 H3 Z M5,6 H11"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="connector">
                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Data" Value="M4,8 H12 M4,8 L6,6 M4,8 L6,10 M12,8 L10,6 M12,8 L10,10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="search">
                    <Setter Property="Stroke" Value="{StaticResource MutedForeground}"/>
                    <Setter Property="Data" Value="M7,3.5 C5.1,3.5 3.5,5.1 3.5,7 C3.5,8.9 5.1,10.5 7,10.5 C8.9,10.5 10.5,8.9 10.5,7 C10.5,5.1 8.9,3.5 7,3.5 Z M9.8,9.8 L12.5,12.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowserTreeItemStyle" TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="1,1"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="HeaderRibbonButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinHeight" Value="20"/>
        </Style>

        <Style x:Key="HeaderSeparatorText" TargetType="TextBlock">
            <Setter Property="Text" Value="|"/>
            <Setter Property="Foreground" Value="{StaticResource PanelBorder}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="AppMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border x:Name="ItemChrome"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    MinHeight="{TemplateBinding MinHeight}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="{StaticResource MutedForeground}"
                                               FontSize="10"
                                               Margin="24,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="2"
                                          Data="M4,3 L8,7 L4,11"
                                          Stroke="{StaticResource MutedForeground}"
                                          StrokeThickness="1.4"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Width="8"
                                          Height="10"
                                          Margin="6,0,0,0"
                                          Stretch="Uniform"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   Placement="Bottom">
                                <Border Background="{StaticResource PanelBg}"
                                        BorderBrush="{StaticResource PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        MinWidth="180"
                                        Padding="5"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.12"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource HoverBg}"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource SoftBorder}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource SelectionBg}"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#CFE3FA"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                                <Setter Property="Padding" Value="7,0"/>
                                <Setter Property="MinHeight" Value="20"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource AppMenuItemStyle}"/>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="5,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="{StaticResource SoftBorder}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorCircleButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="SwatchChrome" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedStyleTarget" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource SubtleForeground}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelBg}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CFE3FA"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShapeToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource ActiveToolButtonConverter}">
                                        <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                                        <Binding Path="DataContext.ActiveCanvasShapeTool" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="DataContext.PendingCanvasItemPlacement" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SelectionBg}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HoverBg}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CFE3FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SelectionBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolboxCardButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HoverBg}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CFE3FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SelectionBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
</ResourceDictionary>
