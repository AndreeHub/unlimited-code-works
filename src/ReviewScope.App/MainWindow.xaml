<Window x:Class="ReviewScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:canvas="clr-namespace:ReviewScope.Canvas;assembly=ReviewScope.Canvas"
        xmlns:controls="clr-namespace:ReviewScope.App.Controls"
        xmlns:vm="clr-namespace:ReviewScope.App.ViewModels"
        Title="unlimited-code-works" Height="900" Width="1500"
        MinHeight="720" MinWidth="1180"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource ShellBg}"
        FontFamily="{StaticResource AppFont}"
        PreviewKeyDown="OnWindowPreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveWorkCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveWorkAsCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopySelectedBoardItemsCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteBoardItemsCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MainWindowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ============================ Unified toolbar (Row 0) ============================ -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1">
            <DockPanel Margin="10,0" LastChildFill="True">

                <!-- Right cluster: view actions + theme -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Click="OnFrameAll" ToolTip="Frame all (zoom to fit)">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3 6V3h3 M14 3h3v3 M17 14v3h-3 M6 17H3v-3"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ToggleBackgroundCommand}" ToolTip="Toggle dot / line grid">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 3.5h13v13h-13z M3.5 8h13 M3.5 12.5h13 M8 3.5v13 M12.5 3.5v13"/>
                    </Button>
                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    <ToggleButton x:Name="GearToggle" Style="{StaticResource IconToggleButton}" Checked="OnViewSettingsOpened" ToolTip="View settings">
                        <Path Style="{StaticResource ToolbarGlyph}"
                              Data="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z M10 2.5v2 M10 15.5v2 M2.5 10h2 M15.5 10h2 M4.7 4.7l1.4 1.4 M13.9 13.9l1.4 1.4 M15.3 4.7l-1.4 1.4 M6.1 13.9l-1.4 1.4"/>
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=GearToggle}" Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" PopupAnimation="Fade"
                           IsOpen="{Binding IsChecked, ElementName=GearToggle, Mode=TwoWay}">
                        <Border Width="280" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="1" CornerRadius="8" Margin="0,4,8,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="22" ShadowDepth="4" Opacity="0.16" Color="#0F172A"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Appearance -->
                                <StackPanel Margin="14,12,14,10">
                                    <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedForeground}" Margin="0,0,0,8"/>
                                    <DockPanel LastChildFill="False" Margin="0,2">
                                        <TextBlock DockPanel.Dock="Left" Text="Dark mode" FontSize="12.5" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="DarkModeSwitch" DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  Checked="OnDarkModeToggled" Unchecked="OnDarkModeToggled"/>
                                    </DockPanel>
                                </StackPanel>
                                <Border Height="1" Background="{StaticResource SoftBorder}"/>
                                <!-- Canvas -->
                                <StackPanel Margin="14,10,14,12">
                                    <TextBlock Text="CANVAS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedForeground}" Margin="0,0,0,8"/>
                                    <DockPanel LastChildFill="False" Margin="0,2">
                                        <TextBlock DockPanel.Dock="Left" Text="Line grid" FontSize="12.5" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="LineGridSwitch" DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  Checked="OnLineGridToggled" Unchecked="OnLineGridToggled"/>
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,6,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Snap to grid" FontSize="12.5" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding SnapToGrid, Mode=TwoWay}"/>
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,6,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Show connectors" FontSize="12.5" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding ConnectorsEnabled, Mode=TwoWay}"/>
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,6,0,0"
                                               ToolTip="Drawn = hand-drawn look. Sleek = crisp vector look. Shapes set to Auto follow this.">
                                        <TextBlock DockPanel.Dock="Left" Text="Sleek shapes" FontSize="12.5" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="SleekShapesSwitch" DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  Checked="OnSleekShapesToggled" Unchecked="OnSleekShapesToggled"/>
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button Style="{StaticResource IconButton}" Click="OnToggleTheme" ToolTip="Toggle light / dark">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M16 11.5A6.5 6.5 0 0 1 8.5 4a6.5 6.5 0 1 0 7.5 7.5z"/>
                    </Button>
                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    <Button x:Name="CodePanelToggle" Style="{StaticResource IconButton}" Click="OnToggleCodePanel" ToolTip="Code search &amp; extraction">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M7 7 4 10l3 3 M13 7l3 3-3 3 M11 5.2 9 14.8"/>
                    </Button>
                    <Button x:Name="LeftPanelToggle" Style="{StaticResource IconButton}" Click="OnToggleLeftPanel" ToolTip="Toggle left panel">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 4.5h13v11h-13z M8 4.5v11 M5.2 7.2h1.4 M5.2 9.5h1.4"/>
                    </Button>
                    <Button x:Name="RightPanelToggle" Style="{StaticResource IconButton}" Click="OnToggleRightPanel" ToolTip="Toggle right panel">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 4.5h13v11h-13z M12 4.5v11 M13.4 7.2h1.4 M13.4 9.5h1.4"/>
                    </Button>
                </StackPanel>

                <!-- Search field (command palette opens here in a later phase) -->
                <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Margin="8,0,0,0" Height="32" MinHeight="0"
                        Width="240" Padding="10,0" Background="{StaticResource ShellBg}"
                        Click="OnOpenCommandPalette" ToolTip="Command palette (Ctrl+K)">
                    <DockPanel LastChildFill="True">
                        <Path DockPanel.Dock="Left" Style="{StaticResource ToolbarGlyph}" Width="14" Height="14" Margin="0,0,8,0"
                              Data="M9 15A6 6 0 1 0 9 3a6 6 0 0 0 0 12z M13.5 13.5 17 17"/>
                        <Border DockPanel.Dock="Right" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4"
                                Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="Ctrl K" FontSize="9.5" Foreground="{StaticResource MutedForeground}"/>
                        </Border>
                        <TextBlock Text="Search everything…" FontSize="12" Foreground="{StaticResource MutedForeground}" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>

                <!-- Left cluster: project pill, IO, history, mode toggle -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Project pill (hosts the File menu) -->
                    <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="6"
                            Height="32" Background="{StaticResource PanelBg}" VerticalAlignment="Center">
                        <Menu Background="Transparent" Padding="0" VerticalAlignment="Stretch">
                            <MenuItem Style="{StaticResource ProjectPillMenuItem}">
                                <MenuItem.Header>
                                    <Grid Width="228" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="22" Height="18" CornerRadius="3" Background="{StaticResource AccentBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="UCW" Foreground="White" FontSize="8" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="unlimited-code-works" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Path Grid.Column="2" Style="{StaticResource ToolbarGlyph}" Width="12" Height="12" Margin="8,0,0,0"
                                              Stroke="{StaticResource MutedForeground}" Data="M5.5 8l4.5 4.5L14.5 8"/>
                                    </Grid>
                                </MenuItem.Header>
                                <MenuItem Header="Open UBW Project…" Command="{Binding OpenProjectCommand}"/>
                                <MenuItem Header="Save" Command="{Binding SaveWorkCommand}" InputGestureText="Ctrl+S"/>
                                <MenuItem Header="Save As" Command="{Binding SaveWorkAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                                <Separator/>
                                <MenuItem Header="Import From UBW Project…" Command="{Binding ImportProjectCommand}"/>
                                <Separator/>
                                <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                            </MenuItem>
                        </Menu>
                    </Border>

                    <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="6"
                            Height="32" Background="{StaticResource PanelBg}" VerticalAlignment="Center" Margin="6,0,0,0">
                        <Menu Background="Transparent" Padding="0" VerticalAlignment="Stretch">
                            <MenuItem Style="{StaticResource ProjectPillMenuItem}">
                                <MenuItem.Header>
                                    <Grid Width="74" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0" Style="{StaticResource ToolbarGlyph}" Width="14" Height="14" Margin="0,0,6,0"
                                              Data="M7 7 4 10l3 3 M13 7l3 3-3 3 M11 5.2 9 14.8"/>
                                        <TextBlock Grid.Column="1" Text="Code" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <Path Grid.Column="2" Style="{StaticResource ToolbarGlyph}" Width="11" Height="11" Margin="6,0,0,0"
                                              Stroke="{StaticResource MutedForeground}" Data="M5.5 8l4.5 4.5L14.5 8"/>
                                    </Grid>
                                </MenuItem.Header>
                                <MenuItem Header="Open .sln / .csproj…" Command="{Binding OpenWorkspaceCommand}"/>
                                <MenuItem Header="Open Code Project Folder…" Command="{Binding OpenFolderCommand}"/>
                                <MenuItem Header="Reload Coding Project" Command="{Binding ReloadCodeCommand}"/>
                            </MenuItem>
                        </Menu>
                    </Border>

                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                    <!-- History cluster -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M7 8H13.5a3.5 3.5 0 0 1 0 7H8 M7 8l3-3 M7 8l3 3"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M13 8H6.5a3.5 3.5 0 0 0 0 7H12 M13 8l-3-3 M13 8l-3 3"/>
                    </Button>

                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Mode toggle (the active-mode indicator) -->
                    <Border Background="{StaticResource HoverBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton GroupName="WorkspaceMode" Style="{StaticResource SegmentedStyleTarget}"
                                         Click="OnSelectCanvasMode" IsChecked="{Binding IsCanvasDocumentActive, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ToolbarGlyph}" Width="15" Height="15" Margin="0,0,6,0"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          Data="M3.5 5.5h13v9h-13z M3.5 9h13 M8 9v5.5"/>
                                    <TextBlock Text="Canvas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="WorkspaceMode" Style="{StaticResource SegmentedStyleTarget}"
                                         Click="OnSelectOutlineMode" IsChecked="{Binding IsOutlineDocumentActive, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ToolbarGlyph}" Width="15" Height="15" Margin="0,0,6,0"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          Data="M5 6h2 M9 6h6 M5 10h2 M9 10h6 M5 14h2 M9 14h6"/>
                                    <TextBlock Text="Outline" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <!-- Split view: show the active board + active page side by side. -->
                    <ToggleButton x:Name="SplitViewToggle" Style="{StaticResource IconToggleButton}" Margin="6,0,0,0"
                                  IsChecked="{Binding IsSplitViewActive, Mode=OneWay}"
                                  Command="{Binding ToggleSplitViewCommand}" ToolTip="Split view: canvas + writing side by side">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 4.5h13v11h-13z M10 4.5v11"/>
                    </ToggleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelCol" Width="264" MinWidth="160"/>
                <ColumnDefinition x:Name="LeftSplitterCol" Width="5"/>
                <ColumnDefinition x:Name="CodeLeftCol" Width="0"/>
                <ColumnDefinition x:Name="CodeLeftSplitterCol" Width="0"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightSplitterCol" Width="5"/>
                <ColumnDefinition x:Name="RightPanelCol" Width="320" MinWidth="220" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftPanelFull" Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nav header -->
                    <DockPanel Grid.Row="0" Margin="12,0,6,0">
                        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="28" Height="28"
                                Click="OnToggleLeftPanel" ToolTip="Collapse panel">
                            <Path Style="{StaticResource ToolbarGlyph}" Width="15" Height="15" Data="M3.5 4.5h13v11h-13z M8 4.5v11 M5.2 7.2h1.4 M5.2 9.5h1.4"/>
                        </Button>
                        <TextBlock Text="PROJECT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedForeground}" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- New-document actions -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="12,0,12,8">
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="+ Board" Command="{Binding CreateNewSessionCommand}"/>
                        <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="+ Page" Command="{Binding CreateNewPageCommand}"/>
                        <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="Today" Command="{Binding OpenTodayJournalCommand}"/>
                    </StackPanel>

                    <!-- Filter -->
                    <TextBox x:Name="ProjectNavFilter" Grid.Row="2" Margin="12,0,12,8" Height="28" MinHeight="0"
                             Padding="8,3" FontSize="11" VerticalContentAlignment="Center"
                             TextChanged="OnNavFilterChanged"/>

                    <!-- Document tree: UBW project -> Boards / Pages / Journals. Double-click a document to rename. -->
                    <TreeView x:Name="ProjectDocTree" Grid.Row="3" Margin="6,0,6,8"
                              ItemsSource="{Binding ProjectBrowserRoots}"
                              ItemContainerStyle="{StaticResource BrowserTreeItemStyle}"
                              SelectedItemChanged="OnProjectDocSelectedItemChanged"
                              MouseDoubleClick="OnSessionDoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid Height="24" Background="Transparent"
                                      ToolTip="{Binding Name}"
                                      PreviewMouseLeftButtonDown="OnDocItemMouseDown"
                                      PreviewMouseMove="OnDocItemMouseMove"
                                      PreviewMouseLeftButtonUp="OnDocItemMouseUp">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock x:Name="SessionNameText" Text="{Binding Name}" FontSize="11"
                                                   Foreground="{StaticResource ForegroundBrush}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBox x:Name="SessionNameEditor" Text="{Binding Name, Mode=OneWay}" Visibility="Collapsed"
                                                 Height="20" MinHeight="0" FontSize="11" Padding="4,0"
                                                 VerticalAlignment="Center" VerticalContentAlignment="Center"
                                                 KeyDown="OnSessionNameEditKeyDown" LostFocus="OnSessionNameEditLostFocus"/>
                                    </Grid>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Collapsed left rail: expand + quick new-document actions. -->
            <Border x:Name="LeftRail" Grid.Column="0" Visibility="Collapsed"
                    Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Style="{StaticResource IconButton}" Click="OnToggleLeftPanel" Margin="0,0,0,6" ToolTip="Expand project navigation">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 4.5h13v11h-13z M8 4.5v11 M5.2 7.2h1.4 M5.2 9.5h1.4"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding CreateNewSessionCommand}" ToolTip="New board">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 5.5h13v9h-13z M3.5 8h13 M8 8v6.5"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding CreateNewPageCommand}" ToolTip="New page">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M5.5 3.5h6L15 7v9.5h-9.5z M11.2 3.5V7H14.8"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding OpenTodayJournalCommand}" ToolTip="Today's journal">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M5 5h10v10H5z M5 8h10 M7.5 3.5v2 M12.5 3.5v2"/>
                    </Button>
                </StackPanel>
            </Border>

            <GridSplitter x:Name="LeftSplitter" Grid.Column="1" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Code panel dock-left host (occupied only when the Code panel is attached left). -->
            <ContentControl x:Name="CodeLeftHost" Grid.Column="2"/>
            <GridSplitter x:Name="CodeLeftSplitter" Grid.Column="3" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Visibility="Collapsed" Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <Grid Grid.Column="4" Background="{StaticResource CanvasBg}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SplitCanvasCol" Width="*"/>
                    <ColumnDefinition x:Name="SplitSplitterCol" Width="0"/>
                    <ColumnDefinition x:Name="SplitOutlineCol" Width="0"/>
                </Grid.ColumnDefinitions>

                <Grid.Resources>
                    <!-- One Chrome-style tab. Click the body to activate; ✕ closes (removes from the
                         strip only — the document is not deleted). Active tab is highlighted. -->
                    <DataTemplate x:Key="DocTabTemplate" DataType="{x:Type vm:DocumentTabViewModel}">
                        <Border Margin="0,4,3,0" CornerRadius="7,7,0,0" BorderThickness="1,1,1,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Height="28" MaxWidth="190" MinWidth="96">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource GhostButton}" Padding="9,0,4,0"
                                        HorizontalContentAlignment="Left" Cursor="Hand"
                                        Command="{Binding DataContext.ActivateTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" ToolTip="{Binding Name}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="12" Height="12" Margin="0,0,7,0" Stretch="Uniform"
                                              Stroke="{StaticResource MutedForeground}" StrokeThickness="1.4" Fill="Transparent"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <!-- Page/journal glyph by default; board glyph for canvas tabs. -->
                                                    <Setter Property="Data" Value="M6,3 H13 L17,7 V21 H6 Z M13,3 V7 H17"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCanvas}" Value="True">
                                                            <Setter Property="Data" Value="M3.5,5.5 H16.5 V14.5 H3.5 Z M3.5,9 H16.5 M8,9 V14.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <TextBlock Text="{Binding Name}" FontSize="11.5" VerticalAlignment="Center"
                                                   Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Padding="5,0" Margin="2,0,4,0"
                                        Content="✕" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                        ToolTip="Close tab"
                                        Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>

                    <!-- Horizontal strip host shared by both panes. -->
                    <Style x:Key="DocTabStrip" TargetType="ItemsControl">
                        <Setter Property="ItemTemplate" Value="{StaticResource DocTabTemplate}"/>
                        <Setter Property="ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ItemsControl">
                                    <Border Background="{StaticResource ShellBg}" BorderBrush="{StaticResource PanelBorder}"
                                            BorderThickness="0,0,0,1" Padding="6,0,6,0">
                                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <!-- ===== Canvas pane: tab strip over the board ===== -->
                <Grid Grid.Column="0"
                      Visibility="{Binding IsCanvasPaneVisible, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ItemsControl Grid.Row="0" Style="{StaticResource DocTabStrip}" ItemsSource="{Binding CanvasTabs}"/>

                <Grid x:Name="CanvasHostGrid" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <canvas:CanvasViewport x:Name="CanvasViewport"
                                       Grid.Row="0"
                                       Scene="{Binding Scene, Mode=TwoWay}"
                                       BackgroundMode="{Binding BackgroundMode, Mode=TwoWay}"
                                       GlobalShapeStyle="{Binding GlobalShapeStyle, Mode=TwoWay}"
                                       SnapToGrid="{Binding SnapToGrid}"
                                       ConnectorsEnabled="{Binding ConnectorsEnabled}"
                                       ActiveShapeTool="{Binding ActiveCanvasShapeTool, Mode=TwoWay}"
                                       PendingItemPlacement="{Binding PendingCanvasItemPlacement, Mode=TwoWay}"
                                       ItemPlacementRequestedCommand="{Binding PlaceCanvasItemCommand}"
                                       ShowShapeToolPalette="False"
                                       AllowDrop="True"
                                       Drop="OnCanvasDrop"
                                       DragOver="OnCanvasDragOver"/>

                <!-- ================ Floating Toolbox panel (draw.io shape picker style) ================ -->
                <!-- Toggle button (always visible, top-left of the canvas) -->
                <Button x:Name="ToolboxToggleButton"
                        Style="{StaticResource ToolButton}"
                        Click="OnToggleToolbox"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="14,14,0,0" Padding="10,6"
                        Background="{StaticResource PanelBg}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M4,6 H20 M4,12 H20 M4,18 H20" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="Toolbox" FontSize="11" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Floating panel -->
                <Border x:Name="FloatingToolbox"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="14,54,0,0"
                        Width="240" MaxHeight="520"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsToolboxFloating, Converter={StaticResource BoolVis}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" Color="#0F172A"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Drag header -->
                        <Border Grid.Row="0" Background="{StaticResource HoverBg}" CornerRadius="8,8,0,0" Padding="10,8"
                                MouseLeftButtonDown="OnToolboxHeaderMouseDown"
                                MouseMove="OnToolboxHeaderMouseMove"
                                MouseLeftButtonUp="OnToolboxHeaderMouseUp"
                                Cursor="SizeAll">
                            <Grid>
                                <TextBlock Text="Toolbox" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Click="OnToggleToolbox" Padding="4,0" Content="✕" FontSize="11"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,8,10,12">
                            <StackPanel>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddNoteCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#FFF7ED" VerticalAlignment="Top">
                                            <Path Data="M7,5 H21 V17 L17,21 H7 Z M17,21 V17 H21" Stroke="#C2410C" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Sticky Note" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Quick architectural notes." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddContainerCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#F8FAFC" VerticalAlignment="Top">
                                            <Path Data="M4,5 H20 V19 H4 Z M7,8 H17" Stroke="#64748B" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Architecture Area" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Group related components." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddShapeCommand}" CommandParameter="database">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#CCFBF1" VerticalAlignment="Top">
                                            <Path Data="M6,8 C6,6.3 8.7,5 12,5 C15.3,5 18,6.3 18,8 C18,9.7 15.3,11 12,11 C8.7,11 6,9.7 6,8 Z M6,8 V16 C6,17.7 8.7,19 12,19 C15.3,19 18,17.7 18,16 V8 M6,12 C6,13.7 8.7,15 12,15 C15.3,15 18,13.7 18,12" Stroke="#0F766E" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Database Shape" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Services / data layers." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding PasteMermaidDiagramCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#EFF6FF" VerticalAlignment="Top">
                                            <Path Data="M5,5 H11 V9 H5 Z M13,15 H19 V19 H13 Z M8,9 V13 H16 V15 M16,13 V15" Stroke="#2E7DD7" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Paste Mermaid" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Turn a flowchart into editable blocks." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddSwimLaneCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#DBEAFE" VerticalAlignment="Top">
                                            <Path Data="M5,6 H19 V18 H5 Z M5,10 H19 M12,6 V18" Stroke="#2E7DD7" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Frame Layer" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Horizontal / vertical lanes." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddTextCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#EDE9FE" VerticalAlignment="Top">
                                            <Path Data="M5,7 H19 M12,7 V19 M8,19 H16" Stroke="#7C3AED" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Text Card" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Rich text / markdown." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddOutlineCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" VerticalAlignment="Top">
                                            <Path Data="M5,7 H6 M9,7 H19 M5,12 H6 M9,12 H19 M5,17 H6 M9,17 H16" Stroke="#0F766E" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Bullet List" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Editable Logseq-style outline block." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding OpenTransclusionPickerCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#D1FAE5" VerticalAlignment="Top">
                                            <Path Data="M9,7 H19 M9,12 H19 M9,17 H15 M5,7 V7 M5,12 V12 M5,17 V17" Stroke="#047857" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Search blocks" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Insert or create a block, page, or board." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding ImportExcalidrawLibraryCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#F1F0FF" VerticalAlignment="Top">
                                            <Path Data="M5,5 H11 V11 H5 Z M14,13 a3,3 0 1 0 0.01,0 M13,5 L19,11 M19,5 L13,11" Stroke="#6741D9" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Import Excalidraw" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Drop shapes from an .excalidrawlib file." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ================ Bottom Shape Toolbar (icon strip) ================ -->
                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Margin="0,6,0,8"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="6,5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.18" Color="#0F172A"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="" Click="OnShapeToolbarClick" ToolTip="Select / move (V / Esc)">
                            <Path Data="M5,3 L5,17 L9,13 L11.5,18 L13.5,17 L11,12 L17,12 Z"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="rectangle" Click="OnShapeToolbarClick" ToolTip="Rectangle (1)">
                            <Rectangle Width="16" Height="11" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="square" Click="OnShapeToolbarClick" ToolTip="Square (2)">
                            <Rectangle Width="13" Height="13" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="oval" Click="OnShapeToolbarClick" ToolTip="Ellipse (3)">
                            <Ellipse Width="16" Height="11" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="circle" Click="OnShapeToolbarClick" ToolTip="Circle (4)">
                            <Ellipse Width="13" Height="13" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="triangle" Click="OnShapeToolbarClick" ToolTip="Triangle (5)">
                            <Path Data="M10,2 L18,17 L2,17 Z" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="diamond" Click="OnShapeToolbarClick" ToolTip="Diamond (6)">
                            <Path Data="M10,2 L18,10 L10,18 L2,10 Z" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="hexagon" Click="OnShapeToolbarClick" ToolTip="Hexagon (7)">
                            <Path Data="M6,2 L14,2 L18,10 L14,18 L6,18 L2,10 Z" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="star" Click="OnShapeToolbarClick" ToolTip="Star (8)">
                            <Path Data="M10,2 L12.5,7.5 L18,8 L14,12 L15,18 L10,15 L5,18 L6,12 L2,8 L7.5,7.5 Z"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="line" Click="OnShapeToolbarClick" ToolTip="Line (Q)">
                            <Path Data="M2,16 L18,4" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="arrow" Click="OnShapeToolbarClick" ToolTip="Arrow (E)">
                            <Path Data="M2,16 L17,4 M17,4 L12,5 M17,4 L16,9" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="polyline" Click="OnShapeToolbarClick" ToolTip="Polyline / curve (9)">
                            <Path Data="M2,16 Q6,4 10,10 T18,4" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="freedraw" Click="OnShapeToolbarClick" ToolTip="Draw / pencil (P)">
                            <Path Data="M3,17 C4,13 6,8 11,5 L15,9 C12,14 7,16 3,17 Z M11,5 L13,3 L17,7 L15,9"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="text" Click="OnShapeToolbarAddText" ToolTip="Add Text Card (T)">
                            <Path Data="M3,4 H17 M10,4 V16 M7,16 H13" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="note" Click="OnShapeToolbarAddNote" ToolTip="Add Sticky Note (W)">
                            <Path Data="M3,3 H15 V13 L13,17 H3 Z M13,17 V13 H15"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="outline" Click="OnShapeToolbarAddOutline" ToolTip="Add Bullet List / outline block">
                            <Path Data="M4,5 H5 M8,5 H17 M4,10 H5 M8,10 H17 M4,15 H5 M8,15 H13"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Click="OnShapeToolbarSearchBlocks" ToolTip="Search blocks — insert or reference an existing block">
                            <Path Data="M9,3 A6,6 0 1 0 9,15 A6,6 0 1 0 9,3 M13.5,13.5 L18,18"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Click="OnShapeToolbarImportExcalidraw" ToolTip="Import Excalidraw library (.excalidrawlib)">
                            <Path Data="M5,5 H11 V11 H5 Z M14,13 a3,3 0 1 0 0.01,0 M13,5 L19,11 M19,5 L13,11"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ============ "Search blocks" palette (block reference / transclusion) ============
                     Hosted in a Popup (its own top-level HWND) so it renders ABOVE the Direct2D
                     canvas HwndHost — a plain WPF overlay is occluded by it, exactly like the
                     Ctrl+K command palette above. -->
                <Popup Placement="Center" PlacementTarget="{Binding ElementName=RootGrid}"
                       AllowsTransparency="True" StaysOpen="True" Focusable="True"
                       IsOpen="{Binding IsTransclusionPickerOpen, Mode=TwoWay}">
                    <Grid x:Name="TransclusionScrim"
                          Width="{Binding ActualWidth, ElementName=RootGrid}" Height="{Binding ActualHeight, ElementName=RootGrid}"
                          Background="#66000000" MouseDown="OnTransclusionScrimMouseDown">
                    <Border Width="520" MaxHeight="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}"
                            BorderThickness="1" CornerRadius="12" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.28" Color="#0F172A"/>
                        </Border.Effect>
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <TextBlock Text="Search blocks" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                        Command="{Binding CloseTransclusionPickerCommand}" Padding="6,0" Content="✕" FontSize="12"/>
                            </Grid>
                            <TextBox Grid.Row="1" Margin="0,10,0,8" Padding="8,6"
                                     Text="{Binding TransclusionPickerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12.5"
                                     Background="{StaticResource CanvasBg}" BorderBrush="{StaticResource SoftBorder}"
                                     Foreground="{StaticResource ForegroundBrush}"/>

                            <!-- Create-new actions, driven by the typed query (Logseq's New block / page / whiteboard). -->
                            <StackPanel Grid.Row="2" Margin="0,0,0,6"
                                        Visibility="{Binding HasPaletteQuery, Converter={StaticResource BoolVis}}">
                                <Button Style="{StaticResource ToolboxCardButton}" Margin="0,1" Padding="8,7"
                                        Command="{Binding PaletteNewBlockCommand}" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="5" Background="#ECFDF5" Margin="0,0,9,0">
                                            <Path Data="M5,7 H6 M9,7 H19 M5,12 H6 M9,12 H19 M5,17 H6 M9,17 H16" Stroke="#0F766E" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="15" Height="15" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{Binding PaletteNewBlockLabel}" FontSize="12.5" VerticalAlignment="Center"
                                                   Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Margin="0,1" Padding="8,7"
                                        Command="{Binding PaletteNewPageCommand}" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="5" Background="#EFF6FF" Margin="0,0,9,0">
                                            <Path Data="M7,4 H14 L18,8 V20 H7 Z M14,4 V8 H18" Stroke="#2563EB" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="15" Height="15" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{Binding PaletteNewPageLabel}" FontSize="12.5" VerticalAlignment="Center"
                                                   Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Margin="0,1" Padding="8,7"
                                        Command="{Binding PaletteNewWhiteboardCommand}" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="5" Background="#F5F3FF" Margin="0,0,9,0">
                                            <Path Data="M4,6 H20 V16 H4 Z M8,16 V19 M16,16 V19" Stroke="#7C3AED" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="15" Height="15" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{Binding PaletteNewWhiteboardLabel}" FontSize="12.5" VerticalAlignment="Center"
                                                   Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                                <Border Height="1" Background="{StaticResource SoftBorder}" Margin="2,6,2,0"/>
                            </StackPanel>

                            <ListBox Grid.Row="3" ItemsSource="{Binding TransclusionCandidates}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,1"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalContentAlignment="Stretch" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Padding="6,5"
                                                ToolTip="Click to add, or drag onto the canvas to place"
                                                PreviewMouseLeftButtonDown="OnTransclusionCandidateMouseDown"
                                                PreviewMouseMove="OnTransclusionCandidateMouseMove"
                                                Command="{Binding DataContext.AddTransclusionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Preview}" FontSize="12.5" Margin="{Binding Indent}"
                                                           Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DocumentName}" FontSize="10.5"
                                                           Foreground="{StaticResource SubtleForeground}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    </Grid>
                </Popup>
                </Grid>
                </Grid>

                <!-- Splitter between the canvas pane and the writing pane (visible only in split view). -->
                <GridSplitter x:Name="SplitSplitter" Grid.Column="1" HorizontalAlignment="Stretch" Cursor="SizeWE"
                              Visibility="Collapsed" Background="{StaticResource SoftBorder}">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <!-- Logseq-style outline editor; shown for Page/Journal documents.
                     A centered title heading sits above the outline body, matching the
                     centered writing column the editor itself renders. -->
                <Grid Grid.Column="2"
                      Visibility="{Binding IsOutlinePaneVisible, Converter={StaticResource BoolVis}}"
                      Background="{StaticResource PanelBg}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ItemsControl Grid.Row="0" Style="{StaticResource DocTabStrip}" ItemsSource="{Binding OutlineTabs}"/>
                    <Grid Grid.Row="1" HorizontalAlignment="Stretch" MaxWidth="780"
                          Margin="0,32,10,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pages" FontSize="10.5" Foreground="{StaticResource MutedForeground}"/>
                            <TextBlock Grid.Column="1" Text=" > " FontSize="10.5" Foreground="{StaticResource MutedForeground}" Margin="4,0"/>
                            <TextBlock Text="{Binding OutlineDocumentDisplayTitle}" FontSize="10.5"
                                       Grid.Column="2" Foreground="{StaticResource MutedForeground}" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <!-- Edit it to rename the page. -->
                        <TextBox x:Name="OutlineTitleBox" Grid.Row="1"
                                 Text="{Binding OutlineDocumentDisplayTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="OnOutlineTitleKeyDown" LostKeyboardFocus="OnOutlineTitleLostFocus"
                                 Margin="0,0,0,8" Padding="0" BorderThickness="0" Background="Transparent"
                                 FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="36" FontWeight="SemiBold"
                                 Foreground="{StaticResource ForegroundBrush}"
                                 HorizontalContentAlignment="Left" TextAlignment="Left" />
                        <WrapPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="type" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SubtleForeground}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding OutlineDocumentKindLabel}" FontSize="11" Foreground="{StaticResource MutedForeground}" Margin="0,0,14,0"/>
                            <TextBlock Text="tags" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SubtleForeground}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding OutlineDocumentTagSummary}" FontSize="11" Foreground="{StaticResource MutedForeground}" Margin="0,0,14,0"
                                       TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                            <TextBlock Text="updated" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SubtleForeground}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding OutlineDocumentUpdatedLabel}" FontSize="11" Foreground="{StaticResource MutedForeground}"/>
                        </WrapPanel>
                    </Grid>
                    <canvas:OutlineView x:Name="OutlineEditor" Grid.Row="2"/>
                </Grid>
            </Grid>

            <GridSplitter x:Name="RightSplitter" Grid.Column="5" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Right dock: the Inspector (canvas mode) OR the Code panel (when docked right). -->
            <Grid Grid.Column="6">
                <controls:BoardSidebar x:Name="RightSidebar"
                                       Camera="{Binding Camera, ElementName=CanvasViewport, Mode=TwoWay}"
                                       ViewportWidth="{Binding ActualWidth, ElementName=CanvasViewport}"
                                       ViewportHeight="{Binding ActualHeight, ElementName=CanvasViewport}"/>
                <ContentControl x:Name="CodeRightHost" Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="Project loaded" Foreground="{StaticResource SubtleForeground}" FontSize="11"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Scene.Blocks.Count, StringFormat=Blocks: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Scene.Connections.Count, StringFormat=Connections: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding Scene.Annotations.Count, StringFormat=Notes: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="{Binding SelectedSwimLane.Name, StringFormat=Layer: {0}, TargetNullValue=Layer: --}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <Border Grid.Column="5" Background="{StaticResource SuccessSoft}" CornerRadius="10" Padding="8,2" Margin="24,0,12,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="11"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                </Border>
                <TextBlock Grid.Column="6" Text="{Binding BackgroundMode, StringFormat=Canvas: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ============================ Command palette (Ctrl+K) ============================
             Hosted in a Popup (its own top-level HWND) so it renders ABOVE the Direct2D
             canvas/outliner HwndHosts — a plain WPF overlay would be occluded by them. -->
        <Popup x:Name="CommandPalettePopup" Placement="Center" PlacementTarget="{Binding ElementName=RootGrid}"
               AllowsTransparency="True" StaysOpen="True" Focusable="True">
            <Grid x:Name="CommandPaletteOverlay"
                  Width="{Binding ActualWidth, ElementName=RootGrid}" Height="{Binding ActualHeight, ElementName=RootGrid}"
                  Background="#66101418" MouseDown="OnPaletteScrimMouseDown">
            <Border Width="560" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,90,0,0"
                    Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.22" Color="#0F172A"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="14,12,14,10">
                        <Path DockPanel.Dock="Left" Style="{StaticResource ToolbarGlyph}" Width="16" Height="16" Margin="0,0,10,0"
                              Stroke="{StaticResource MutedForeground}" Data="M9 15A6 6 0 1 0 9 3a6 6 0 0 0 0 12z M13.5 13.5 17 17"/>
                        <Border DockPanel.Dock="Right" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4"
                                Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="esc" FontSize="10" Foreground="{StaticResource MutedForeground}"/>
                        </Border>
                        <TextBox x:Name="PaletteInput" BorderThickness="0" Background="Transparent" FontSize="15"
                                 VerticalContentAlignment="Center" Padding="0"
                                 TextChanged="OnPaletteInputChanged" PreviewKeyDown="OnPaletteInputKeyDown"/>
                    </DockPanel>
                    <Border Height="1" Background="{StaticResource SoftBorder}"/>
                    <ListBox x:Name="PaletteList" MaxHeight="360" Margin="6" BorderThickness="0"
                             Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseLeftButtonUp="OnPaletteListClick">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedForeground}" Margin="6,8,0,3"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Shortcut}" FontSize="10.5"
                                               Foreground="{StaticResource MutedForeground}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding Title}" FontSize="13" Foreground="{StaticResource ForegroundBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
            </Grid>
        </Popup>
    </Grid>
</Window>

