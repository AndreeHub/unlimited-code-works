<Window x:Class="ReviewScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:canvas="clr-namespace:ReviewScope.Canvas;assembly=ReviewScope.Canvas"
        xmlns:controls="clr-namespace:ReviewScope.App.Controls"
        Title="unlimited-code-works" Height="900" Width="1500"
        MinHeight="720" MinWidth="1180"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource ShellBg}"
        FontFamily="{StaticResource AppFont}"
        PreviewKeyDown="OnWindowPreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveWorkCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveWorkAsCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopySelectedBoardItemsCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteBoardItemsCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MainWindowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ============================ Unified toolbar (Row 0) ============================ -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1">
            <DockPanel Margin="10,0" LastChildFill="True">

                <!-- Right cluster: view actions + theme -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Click="OnFrameAll" ToolTip="Frame all (zoom to fit)">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3 6V3h3 M14 3h3v3 M17 14v3h-3 M6 17H3v-3"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ToggleBackgroundCommand}" ToolTip="Toggle dot / line grid">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3.5 3.5h13v13h-13z M3.5 8h13 M3.5 12.5h13 M8 3.5v13 M12.5 3.5v13"/>
                    </Button>
                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    <Button Style="{StaticResource IconButton}" Click="OnToggleTheme" ToolTip="Toggle light / dark">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M16 11.5A6.5 6.5 0 0 1 8.5 4a6.5 6.5 0 1 0 7.5 7.5z"/>
                    </Button>
                </StackPanel>

                <!-- Search field (command palette opens here in a later phase) -->
                <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Margin="8,0,0,0" Height="32" MinHeight="0"
                        Width="240" Padding="10,0" Background="{StaticResource ShellBg}" Cursor="Arrow"
                        ToolTip="Search (command palette — coming soon)">
                    <DockPanel LastChildFill="True">
                        <Path DockPanel.Dock="Left" Style="{StaticResource ToolbarGlyph}" Width="14" Height="14" Margin="0,0,8,0"
                              Data="M9 15A6 6 0 1 0 9 3a6 6 0 0 0 0 12z M13.5 13.5 17 17"/>
                        <Border DockPanel.Dock="Right" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4"
                                Padding="5,1" VerticalAlignment="Center">
                            <TextBlock Text="Ctrl K" FontSize="9.5" Foreground="{StaticResource MutedForeground}"/>
                        </Border>
                        <TextBlock Text="Search everything…" FontSize="12" Foreground="{StaticResource MutedForeground}" VerticalAlignment="Center"/>
                    </DockPanel>
                </Button>

                <!-- Left cluster: project pill, IO, history, mode toggle -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Project pill (hosts the File menu) -->
                    <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="6"
                            Height="32" Background="{StaticResource PanelBg}" VerticalAlignment="Center">
                        <Menu Background="Transparent" Padding="0" VerticalAlignment="Stretch">
                            <MenuItem Style="{StaticResource ProjectPillMenuItem}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="22" Height="18" CornerRadius="3" Background="{StaticResource AccentBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="UCW" Foreground="White" FontSize="8" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="unlimited-code-works" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                        <Path Style="{StaticResource ToolbarGlyph}" Width="12" Height="12" Margin="7,0,0,0"
                                              Stroke="{StaticResource MutedForeground}" Data="M5.5 8l4.5 4.5L14.5 8"/>
                                    </StackPanel>
                                </MenuItem.Header>
                                <MenuItem Header="Open Project…" Command="{Binding OpenWorkspaceCommand}"/>
                                <MenuItem Header="Open Folder…" Command="{Binding OpenFolderCommand}"/>
                                <MenuItem Header="Reload Code" Command="{Binding ReloadCodeCommand}"/>
                                <Separator/>
                                <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                                <Separator/>
                                <MenuItem Header="Save" Command="{Binding SaveWorkCommand}" InputGestureText="Ctrl+S"/>
                                <MenuItem Header="Save As" Command="{Binding SaveWorkAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                                <Separator/>
                                <MenuItem Header="Load" Command="{Binding LoadWorkCommand}"/>
                            </MenuItem>
                        </Menu>
                    </Border>

                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                    <!-- IO cluster -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding OpenFolderCommand}" ToolTip="Open folder / .sln">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M3 6.5A1.5 1.5 0 0 1 4.5 5h3.4l1.3 1.6h6.3A1.5 1.5 0 0 1 17 8.1v6.4A1.5 1.5 0 0 1 15.5 16h-11A1.5 1.5 0 0 1 3 14.5z"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ReloadCodeCommand}" ToolTip="Reload">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M15.5 6.5A6 6 0 1 0 16.4 12 M15.8 4v3h-3"/>
                    </Button>

                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                    <!-- History cluster -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M7 8H13.5a3.5 3.5 0 0 1 0 7H8 M7 8l3-3 M7 8l3 3"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)">
                        <Path Style="{StaticResource ToolbarGlyph}" Data="M13 8H6.5a3.5 3.5 0 0 0 0 7H12 M13 8l-3-3 M13 8l-3 3"/>
                    </Button>

                    <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Mode toggle (the active-mode indicator) -->
                    <Border Background="{StaticResource HoverBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton GroupName="WorkspaceMode" Style="{StaticResource SegmentedStyleTarget}"
                                         Click="OnSelectCanvasMode" IsChecked="{Binding IsCanvasDocumentActive, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ToolbarGlyph}" Width="15" Height="15" Margin="0,0,6,0"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          Data="M3.5 5.5h13v9h-13z M3.5 9h13 M8 9v5.5"/>
                                    <TextBlock Text="Canvas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="WorkspaceMode" Style="{StaticResource SegmentedStyleTarget}"
                                         Click="OnSelectOutlineMode" IsChecked="{Binding IsOutlineDocumentActive, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ToolbarGlyph}" Width="15" Height="15" Margin="0,0,6,0"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          Data="M5 6h2 M9 6h6 M5 10h2 M9 10h6 M5 14h2 M9 14h6"/>
                                    <TextBlock Text="Outline" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================ Document tab strip (Row 1) ============================ -->
        <Border Grid.Row="1" Background="{StaticResource ShellBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0,8,0" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="NewSessionButton" Style="{StaticResource IconButton}" Width="26" Height="26"
                            Command="{Binding CreateNewSessionCommand}" ToolTip="New board">
                        <Path Style="{StaticResource ToolbarGlyph}" Width="14" Height="14" Data="M10 4.5v11 M4.5 10h11"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Width="26" Height="26"
                            Command="{Binding DeleteSelectedSessionCommand}" ToolTip="Delete document">
                        <Path Style="{StaticResource ToolbarGlyph}" Width="14" Height="14" Data="M4 5.5h12 M7.5 5.5V4h5v1.5 M5.5 5.5l.7 10h7.6l.7-10"/>
                    </Button>
                </StackPanel>
                <ListBox x:Name="SessionTabs"
                         Background="Transparent" BorderThickness="0" VerticalAlignment="Stretch"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         SelectionChanged="OnSessionTabSelectionChanged"
                         MouseDoubleClick="OnSessionDoubleClick"
                         PreviewMouseLeftButtonDown="OnSessionTabMouseLeftButtonDown"
                         PreviewMouseMove="OnSessionTabMouseMove"
                         PreviewMouseLeftButtonUp="OnSessionTabMouseLeftButtonUp"
                         LostMouseCapture="OnSessionTabLostMouseCapture"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource DocumentTabItem}">
                            <EventSetter Event="Loaded" Handler="OnSessionTabLoaded"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Style="{StaticResource DocumentTabGlyph}"/>
                                <Grid>
                                    <TextBlock x:Name="SessionNameText"
                                               Text="{Binding Name}"
                                               FontSize="11.5"
                                               VerticalAlignment="Center"
                                               ToolTip="Double-click to rename. Drag to reorder."/>
                                    <TextBox x:Name="SessionNameEditor"
                                             Text="{Binding Name, Mode=OneWay}"
                                             Visibility="Collapsed"
                                             MinWidth="110"
                                             MaxWidth="220"
                                             Height="22"
                                             MinHeight="0"
                                             FontSize="11.5"
                                             Padding="6,1"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             KeyDown="OnSessionNameEditKeyDown"
                                             LostFocus="OnSessionNameEditLostFocus"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightSplitterCol" Width="5"/>
                <ColumnDefinition x:Name="RightPanelCol" Width="320" MinWidth="220" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <TabControl x:Name="LeftTabs" SelectedIndex="{Binding SelectedLeftTabIndex, Mode=TwoWay}" Margin="10,8,10,8">
                        <TabItem Header="Explorer" x:Name="LeftTabExplorer"
                                 Visibility="{Binding IsCanvasDocumentActive, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding WorkspacePath}" Foreground="{StaticResource ForegroundBrush}"
                                                   FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <DockPanel Margin="0,4,0,0">
                                            <TextBlock DockPanel.Dock="Left" Text="Branch" Foreground="{StaticResource MutedForeground}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="BranchComboBox"
                                                      Style="{StaticResource BranchComboBox}"
                                                      ItemsSource="{Binding AvailableBranches}"
                                                      SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                                                      SelectionChanged="OnBranchComboSelectionChanged"/>
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="6,0,0,0">
                                        <Button Style="{StaticResource ToolButton}" Click="OnCollapseAll"
                                                Width="26" Height="26" MinHeight="0" Padding="0" Margin="0,0,3,0"
                                                ToolTip="Collapse all">
                                            <Viewbox Width="12" Height="12">
                                                <Path Style="{StaticResource BrowserIconPathStyle}"
                                                      Data="M3,4 H13 M5,7 H11 M7,10 H9"/>
                                            </Viewbox>
                                        </Button>
                                        <Button Style="{StaticResource ToolButton}" Click="OnExpandAll"
                                                Width="26" Height="26" MinHeight="0" Padding="0"
                                                ToolTip="Expand all">
                                            <Viewbox Width="12" Height="12">
                                                <Path Style="{StaticResource BrowserIconPathStyle}"
                                                      Data="M3,4 H9 M3,8 H11 M3,12 H13"/>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <DockPanel Grid.Row="1" Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Command="{Binding ApplyExplorerSearchCommand}"
                                            Width="32" Height="28" MinHeight="0" Padding="0" Margin="6,0,0,0" ToolTip="Find files">
                                        <Viewbox Width="13" Height="13">
                                            <Path Style="{StaticResource BrowserIconPathStyle}" Data="M7,3.5 C5.1,3.5 3.5,5.1 3.5,7 C3.5,8.9 5.1,10.5 7,10.5 C8.9,10.5 10.5,8.9 10.5,7 C10.5,5.1 8.9,3.5 7,3.5 Z M9.8,9.8 L12.5,12.5"/>
                                        </Viewbox>
                                    </Button>
                                    <TextBox Text="{Binding ExplorerSearchQuery, UpdateSourceTrigger=PropertyChanged}" FontSize="11"
                                             Height="28" MinHeight="0" Padding="8,3" VerticalContentAlignment="Center"
                                             KeyDown="OnExplorerSearchKeyDown"/>
                                </DockPanel>

                                <TabControl Grid.Row="2" Margin="0">
                                    <TabItem Header="Solution">
                                        <TreeView x:Name="ExplorerTree"
                                                  ItemsSource="{Binding ExplorerRoots}"
                                                  MouseDoubleClick="OnExplorerDoubleClick"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  Margin="0,8,0,0">
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <Grid Height="22" ToolTip="{Binding FilePath}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}"
                                                                   FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                            <TreeView.ItemContainerStyle>
                                                <StaticResource ResourceKey="BrowserTreeItemStyle"/>
                                            </TreeView.ItemContainerStyle>
                                        </TreeView>
                                    </TabItem>

                                    <TabItem Header="Files">
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding FileExplorerRootPath}"
                                                       Foreground="{StaticResource MutedForeground}"
                                                       FontSize="9.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,6"/>
                                            <TreeView Grid.Row="1"
                                                      x:Name="FileExplorerTree"
                                                      ItemsSource="{Binding FileExplorerRoots}"
                                                      MouseDoubleClick="OnExplorerDoubleClick"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <TreeView.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                        <Grid Height="22" ToolTip="{Binding FilePath}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="18"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}"
                                                                       FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </HierarchicalDataTemplate>
                                                </TreeView.ItemTemplate>
                                                <TreeView.ItemContainerStyle>
                                                    <StaticResource ResourceKey="BrowserTreeItemStyle"/>
                                                </TreeView.ItemContainerStyle>
                                            </TreeView>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Symbols" x:Name="LeftTabSymbols"
                                 Visibility="{Binding IsCanvasDocumentActive, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding SelectedSymbolsHeader}" Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                                <TreeView Grid.Row="1" ItemsSource="{Binding SymbolRoots}"
                                          MouseDoubleClick="OnSymbolsDoubleClick"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <Grid Margin="0,2" ToolTip="Double-click to add to canvas">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}"
                                                               FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding RangeText}" Foreground="{StaticResource MutedForeground}"
                                                               FontSize="9.5" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                    <TreeView.ItemContainerStyle>
                                        <StaticResource ResourceKey="BrowserTreeItemStyle"/>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Notes" x:Name="LeftTabNotes"
                                 Visibility="{Binding IsOutlineDocumentActive, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Style="{StaticResource HeaderRibbonButton}" Content="+ Board" Command="{Binding CreateNewSessionCommand}"/>
                                    <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                                    <Button Style="{StaticResource HeaderRibbonButton}" Content="+ Page" Command="{Binding CreateNewPageCommand}"/>
                                    <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                                    <Button Style="{StaticResource HeaderRibbonButton}" Content="Today" Command="{Binding OpenTodayJournalCommand}"/>
                                </StackPanel>
                                <ListBox x:Name="ProjectDocList" Grid.Row="1"
                                         SelectedItem="{Binding SelectedSession}"
                                         SelectionChanged="OnProjectDocSelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontSize="9.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedForeground}" Margin="2,10,0,3"/>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="22" ToolTip="{Binding Name}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11"
                                                           Foreground="{StaticResource ForegroundBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Graph" x:Name="LeftTabGraph"
                                 Visibility="{Binding IsOutlineDocumentActive, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,10,0,0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,0">
                                    <Border Width="48" Height="48" CornerRadius="12" BorderBrush="{StaticResource PanelBorder}"
                                            BorderThickness="1.5" Background="{StaticResource PanelBg}" Margin="0,0,0,12">
                                        <Path Style="{StaticResource ToolbarGlyph}" Width="22" Height="22"
                                              Stroke="{StaticResource MutedForeground}"
                                              Data="M6 6a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z M14.5 8a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z M8 15a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z M7 5.2 13 6 M7.3 11.6 13.4 7.4"/>
                                    </Border>
                                    <TextBlock Text="Graph view" FontWeight="SemiBold" FontSize="12.5"
                                               Foreground="{StaticResource SubtleForeground}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Linked-reference graph for pages and journals — coming soon."
                                               FontSize="11" Foreground="{StaticResource MutedForeground}"
                                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="190" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Search" x:Name="LeftTabSearch">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Command="{Binding RefreshBoardSearchCommand}"
                                            Width="32" Height="28" MinHeight="0" Padding="0" Margin="6,0,0,0" ToolTip="Search board">
                                        <Viewbox Width="13" Height="13">
                                            <Path Style="{StaticResource BrowserIconPathStyle}" Data="M7,3.5 C5.1,3.5 3.5,5.1 3.5,7 C3.5,8.9 5.1,10.5 7,10.5 C8.9,10.5 10.5,8.9 10.5,7 C10.5,5.1 8.9,3.5 7,3.5 Z M9.8,9.8 L12.5,12.5"/>
                                        </Viewbox>
                                    </Button>
                                    <TextBox Text="{Binding BoardSearchQuery, UpdateSourceTrigger=PropertyChanged}" FontSize="11"
                                             Height="28" MinHeight="0" Padding="8,3" VerticalContentAlignment="Center"/>
                                </DockPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding BoardSearchResults}" MouseDoubleClick="OnBoardSearchDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontSize="10.5" Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Detail}" FontSize="9.5" Foreground="{StaticResource MutedForeground}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                    </TabControl>

                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <Grid Grid.Column="2" Background="{StaticResource CanvasBg}">
                <Grid x:Name="CanvasHostGrid"
                      Visibility="{Binding IsCanvasDocumentActive, Converter={StaticResource BoolVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <canvas:CanvasViewport x:Name="CanvasViewport"
                                       Grid.Row="0"
                                       Scene="{Binding Scene, Mode=TwoWay}"
                                       BackgroundMode="{Binding BackgroundMode, Mode=TwoWay}"
                                       SnapToGrid="{Binding SnapToGrid}"
                                       ConnectorsEnabled="{Binding ConnectorsEnabled}"
                                       ActiveShapeTool="{Binding ActiveCanvasShapeTool, Mode=TwoWay}"
                                       PendingItemPlacement="{Binding PendingCanvasItemPlacement, Mode=TwoWay}"
                                       ItemPlacementRequestedCommand="{Binding PlaceCanvasItemCommand}"
                                       ShowShapeToolPalette="False"
                                       AllowDrop="True"
                                       Drop="OnCanvasDrop"
                                       DragOver="OnCanvasDragOver"/>

                <!-- ================ Floating Toolbox panel (draw.io shape picker style) ================ -->
                <!-- Toggle button (always visible, top-left of the canvas) -->
                <Button x:Name="ToolboxToggleButton"
                        Style="{StaticResource ToolButton}"
                        Click="OnToggleToolbox"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="14,14,0,0" Padding="10,6"
                        Background="{StaticResource PanelBg}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M4,6 H20 M4,12 H20 M4,18 H20" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="Toolbox" FontSize="11" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Floating panel -->
                <Border x:Name="FloatingToolbox"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="14,54,0,0"
                        Width="240" MaxHeight="520"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsToolboxFloating, Converter={StaticResource BoolVis}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" Color="#0F172A"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Drag header -->
                        <Border Grid.Row="0" Background="{StaticResource HoverBg}" CornerRadius="8,8,0,0" Padding="10,8"
                                MouseLeftButtonDown="OnToolboxHeaderMouseDown"
                                MouseMove="OnToolboxHeaderMouseMove"
                                MouseLeftButtonUp="OnToolboxHeaderMouseUp"
                                Cursor="SizeAll">
                            <Grid>
                                <TextBlock Text="Toolbox" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Click="OnToggleToolbox" Padding="4,0" Content="✕" FontSize="11"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,8,10,12">
                            <StackPanel>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddNoteCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#FFF7ED" VerticalAlignment="Top">
                                            <Path Data="M7,5 H21 V17 L17,21 H7 Z M17,21 V17 H21" Stroke="#C2410C" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Sticky Note" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Quick architectural notes." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddContainerCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#F8FAFC" VerticalAlignment="Top">
                                            <Path Data="M4,5 H20 V19 H4 Z M7,8 H17" Stroke="#64748B" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Architecture Area" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Group related components." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddShapeCommand}" CommandParameter="database">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#CCFBF1" VerticalAlignment="Top">
                                            <Path Data="M6,8 C6,6.3 8.7,5 12,5 C15.3,5 18,6.3 18,8 C18,9.7 15.3,11 12,11 C8.7,11 6,9.7 6,8 Z M6,8 V16 C6,17.7 8.7,19 12,19 C15.3,19 18,17.7 18,16 V8 M6,12 C6,13.7 8.7,15 12,15 C15.3,15 18,13.7 18,12" Stroke="#0F766E" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Database Shape" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Services / data layers." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddSwimLaneCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#DBEAFE" VerticalAlignment="Top">
                                            <Path Data="M5,6 H19 V18 H5 Z M5,10 H19 M12,6 V18" Stroke="#2E7DD7" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Frame Layer" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Horizontal / vertical lanes." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding AddTextCardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#EDE9FE" VerticalAlignment="Top">
                                            <Path Data="M5,7 H19 M12,7 V19 M8,19 H16" Stroke="#7C3AED" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Text Card" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Rich text / markdown." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource ToolboxCardButton}" Command="{Binding OpenTransclusionPickerCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="6" Background="#D1FAE5" VerticalAlignment="Top">
                                            <Path Data="M9,7 H19 M9,12 H19 M9,17 H15 M5,7 V7 M5,12 V12 M5,17 V17" Stroke="#047857" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Block Reference" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                            <TextBlock Text="Mirror a note bullet here ((live))." FontSize="10.5" Foreground="{StaticResource SubtleForeground}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ================ Bottom Shape Toolbar (icon strip) ================ -->
                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Margin="0,6,0,8"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="6,5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.18" Color="#0F172A"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="" Click="OnShapeToolbarClick" ToolTip="Select / move (V / Esc)">
                            <Path Data="M5,3 L5,17 L9,13 L11.5,18 L13.5,17 L11,12 L17,12 Z"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="rectangle" Click="OnShapeToolbarClick" ToolTip="Rectangle (1)">
                            <Rectangle Width="16" Height="11" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="square" Click="OnShapeToolbarClick" ToolTip="Square (2)">
                            <Rectangle Width="13" Height="13" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="oval" Click="OnShapeToolbarClick" ToolTip="Ellipse (3)">
                            <Ellipse Width="16" Height="11" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="circle" Click="OnShapeToolbarClick" ToolTip="Circle (4)">
                            <Ellipse Width="13" Height="13" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="triangle" Click="OnShapeToolbarClick" ToolTip="Triangle (5)">
                            <Path Data="M10,2 L18,17 L2,17 Z" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="14" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="diamond" Click="OnShapeToolbarClick" ToolTip="Diamond (6)">
                            <Path Data="M10,2 L18,10 L10,18 L2,10 Z" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="hexagon" Click="OnShapeToolbarClick" ToolTip="Hexagon (7)">
                            <Path Data="M6,2 L14,2 L18,10 L14,18 L6,18 L2,10 Z" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="star" Click="OnShapeToolbarClick" ToolTip="Star (8)">
                            <Path Data="M10,2 L12.5,7.5 L18,8 L14,12 L15,18 L10,15 L5,18 L6,12 L2,8 L7.5,7.5 Z"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="line" Click="OnShapeToolbarClick" ToolTip="Line (Q)">
                            <Path Data="M2,16 L18,4" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="arrow" Click="OnShapeToolbarClick" ToolTip="Arrow (E)">
                            <Path Data="M2,16 L17,4 M17,4 L12,5 M17,4 L16,9" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="polyline" Click="OnShapeToolbarClick" ToolTip="Polyline / curve (9)">
                            <Path Data="M2,16 Q6,4 10,10 T18,4" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Rectangle Width="1" Margin="4,4" Fill="{StaticResource SoftBorder}"/>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="text" Click="OnShapeToolbarAddText" ToolTip="Add Text Card (T)">
                            <Path Data="M3,4 H17 M10,4 V16 M7,16 H13" Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ShapeToolbarButton}" Tag="note" Click="OnShapeToolbarAddNote" ToolTip="Add Sticky Note (W)">
                            <Path Data="M3,3 H15 V13 L13,17 H3 Z M13,17 V13 H15"
                                  Stroke="{StaticResource ForegroundBrush}" StrokeThickness="1.4" Fill="Transparent"
                                  StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ============ Block-reference (transclusion) picker overlay ============ -->
                <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="50"
                      Background="#66000000"
                      Visibility="{Binding IsTransclusionPickerOpen, Converter={StaticResource BoolVis}}">
                    <Border Width="520" MaxHeight="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}"
                            BorderThickness="1" CornerRadius="12" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.28" Color="#0F172A"/>
                        </Border.Effect>
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <TextBlock Text="Reference a block" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                        Command="{Binding CloseTransclusionPickerCommand}" Padding="6,0" Content="✕" FontSize="12"/>
                            </Grid>
                            <TextBox Grid.Row="1" Margin="0,10,0,8" Padding="8,6"
                                     Text="{Binding TransclusionPickerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12.5"
                                     Background="{StaticResource CanvasBg}" BorderBrush="{StaticResource SoftBorder}"
                                     Foreground="{StaticResource ForegroundBrush}"/>
                            <ListBox Grid.Row="2" ItemsSource="{Binding TransclusionCandidates}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,1"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalContentAlignment="Stretch" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Padding="6,5"
                                                ToolTip="Click to add, or drag onto the canvas to place"
                                                PreviewMouseLeftButtonDown="OnTransclusionCandidateMouseDown"
                                                PreviewMouseMove="OnTransclusionCandidateMouseMove"
                                                Command="{Binding DataContext.AddTransclusionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Preview}" FontSize="12.5" Margin="{Binding Indent}"
                                                           Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DocumentName}" FontSize="10.5"
                                                           Foreground="{StaticResource SubtleForeground}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
                </Grid>

                <!-- Logseq-style outline editor; shown for Page/Journal documents.
                     A centered title heading sits above the outline body, matching the
                     centered writing column the editor itself renders. -->
                <Grid Visibility="{Binding IsOutlineDocumentActive, Converter={StaticResource BoolVis}}"
                      Background="{StaticResource PanelBg}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Logseq-style page title: a large left-aligned heading whose block matches
                         the centered ~720px writing column, so its left edge lines up with the
                         bullets below it. Edit it to rename the page. -->
                    <TextBox x:Name="OutlineTitleBox" Grid.Row="0"
                             Text="{Binding OutlineDocumentTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="OnOutlineTitleKeyDown" LostKeyboardFocus="OnOutlineTitleLostFocus"
                             HorizontalAlignment="Center" MaxWidth="720" MinWidth="680"
                             Margin="0,30,12,6" Padding="22,0,0,0" BorderThickness="0" Background="Transparent"
                             FontFamily="Segoe UI" FontSize="32" FontWeight="Bold"
                             Foreground="{StaticResource ForegroundBrush}"
                             HorizontalContentAlignment="Left" TextAlignment="Left" />
                    <canvas:OutlineView x:Name="OutlineEditor" Grid.Row="1"/>
                </Grid>
            </Grid>

            <GridSplitter x:Name="RightSplitter" Grid.Column="3" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <controls:BoardSidebar x:Name="RightSidebar" Grid.Column="4"
                                   Camera="{Binding Camera, ElementName=CanvasViewport, Mode=TwoWay}"
                                   ViewportWidth="{Binding ActualWidth, ElementName=CanvasViewport}"
                                   ViewportHeight="{Binding ActualHeight, ElementName=CanvasViewport}"/>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="Project loaded" Foreground="{StaticResource SubtleForeground}" FontSize="11"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Scene.Blocks.Count, StringFormat=Blocks: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Scene.Connections.Count, StringFormat=Connections: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding Scene.Annotations.Count, StringFormat=Notes: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="{Binding SelectedSwimLane.Name, StringFormat=Layer: {0}, TargetNullValue=Layer: --}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <Border Grid.Column="5" Background="{StaticResource SuccessSoft}" CornerRadius="10" Padding="8,2" Margin="24,0,12,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="11"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                </Border>
                <TextBlock Grid.Column="6" Text="{Binding BackgroundMode, StringFormat=Canvas: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>

