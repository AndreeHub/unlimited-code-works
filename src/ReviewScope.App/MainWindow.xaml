<Window x:Class="ReviewScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:canvas="clr-namespace:ReviewScope.Canvas;assembly=ReviewScope.Canvas"
        xmlns:controls="clr-namespace:ReviewScope.App.Controls"
        Title="unlimited-code-works" Height="900" Width="1500"
        MinHeight="720" MinWidth="1180"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource ShellBg}"
        FontFamily="{StaticResource AppFont}"
        PreviewKeyDown="OnWindowPreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveWorkCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveWorkAsCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopySelectedBoardItemsCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteBoardItemsCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MainWindowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="118"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="39"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="4"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="12,2">
                    <Border BorderBrush="{StaticResource PanelBorder}"
                            BorderThickness="1"
                            CornerRadius="5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Height="20"
                            Background="{StaticResource PanelBg}">
                        <Button x:Name="FileMenuButton"
                                Style="{StaticResource GhostButton}"
                                Content="File"
                                Padding="7,0"
                                MinHeight="18"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Click="OnFileMenuButtonClick">
                            <Button.ContextMenu>
                                <ContextMenu Placement="Bottom"
                                             PlacementTarget="{Binding ElementName=FileMenuButton}"
                                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Settings"
                                              Command="{Binding OpenSettingsCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Save"
                                              Command="{Binding SaveWorkCommand}"
                                              InputGestureText="Ctrl+S"/>
                                    <MenuItem Header="Save As"
                                              Command="{Binding SaveWorkAsCommand}"
                                              InputGestureText="Ctrl+Shift+S"/>
                                    <Separator/>
                                    <MenuItem Header="Load"
                                              Command="{Binding LoadWorkCommand}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Border>
                </Border>

                <Border Grid.Row="1" Grid.Column="0"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="5,3"
                        Margin="12,0,10,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="Open Project" Command="{Binding OpenWorkspaceCommand}"/>
                        <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="Folder" Command="{Binding OpenFolderCommand}"/>
                        <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="Reload" Command="{Binding ReloadCodeCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="5,3"
                        Margin="236,0,10,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="Undo" Command="{Binding UndoCommand}"/>
                        <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                        <Button Style="{StaticResource HeaderRibbonButton}" Content="Redo" Command="{Binding RedoCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="2"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,6"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="18" Height="18" CornerRadius="4" Background="{StaticResource AccentSoft}" Margin="0,0,7,0">
                            <TextBlock Text="UCW" Foreground="{StaticResource AccentBrush}" FontSize="7" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="unlimited-code-works" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Style="{StaticResource ToolButton}" Content="Frame" Click="OnFrameAll" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource ToolButton}" Content="Grid" Command="{Binding ToggleBackgroundCommand}"/>
                </StackPanel>

                <Border Grid.Row="2" Grid.ColumnSpan="4" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,1,0,0">
                    <DockPanel Margin="12,5,12,5">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="NewSessionButton" Style="{StaticResource HeaderRibbonButton}" Content="New Board" Command="{Binding CreateNewSessionCommand}"/>
                            <TextBlock Style="{StaticResource HeaderSeparatorText}"/>
                            <Button Style="{StaticResource HeaderRibbonButton}" Content="Delete" Command="{Binding DeleteSelectedSessionCommand}"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Left" Text="Boards:" Foreground="{StaticResource SubtleForeground}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ListBox x:Name="SessionTabs"
                                 ItemsSource="{Binding Sessions}"
                                 SelectedItem="{Binding SelectedSession}"
                                 SelectionChanged="OnSessionTabSelectionChanged"
                                 MouseDoubleClick="OnSessionDoubleClick"
                                 PreviewMouseLeftButtonDown="OnSessionTabMouseLeftButtonDown"
                                 PreviewMouseMove="OnSessionTabMouseMove"
                                 PreviewMouseLeftButtonUp="OnSessionTabMouseLeftButtonUp"
                                 LostMouseCapture="OnSessionTabLostMouseCapture"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <EventSetter Event="Loaded" Handler="OnSessionTabLoaded"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock x:Name="SessionNameText"
                                                   Text="{Binding Name}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   ToolTip="Double-click to rename. Drag to reorder boards."/>
                                        <TextBox x:Name="SessionNameEditor"
                                                 Text="{Binding Name, Mode=OneWay}"
                                                 Visibility="Collapsed"
                                                 MinWidth="110"
                                                 MaxWidth="220"
                                                 Height="22"
                                                 MinHeight="0"
                                                 FontSize="11"
                                                 Padding="6,1"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 KeyDown="OnSessionNameEditKeyDown"
                                                 LostFocus="OnSessionNameEditLostFocus"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="220" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <TabControl SelectedIndex="{Binding SelectedLeftTabIndex, Mode=TwoWay}" Margin="10,8,10,8">
                        <TabItem Header="Explorer">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding WorkspacePath}" Foreground="{StaticResource ForegroundBrush}"
                                                   FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <DockPanel Margin="0,4,0,0">
                                            <TextBlock DockPanel.Dock="Left" Text="Branch" Foreground="{StaticResource MutedForeground}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="BranchComboBox"
                                                      Style="{StaticResource BranchComboBox}"
                                                      ItemsSource="{Binding AvailableBranches}"
                                                      SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                                                      SelectionChanged="OnBranchComboSelectionChanged"/>
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="6,0,0,0">
                                        <Button Style="{StaticResource ToolButton}" Click="OnCollapseAll"
                                                Width="26" Height="26" MinHeight="0" Padding="0" Margin="0,0,3,0"
                                                ToolTip="Collapse all">
                                            <Viewbox Width="12" Height="12">
                                                <Path Style="{StaticResource BrowserIconPathStyle}"
                                                      Data="M3,4 H13 M5,7 H11 M7,10 H9"/>
                                            </Viewbox>
                                        </Button>
                                        <Button Style="{StaticResource ToolButton}" Click="OnExpandAll"
                                                Width="26" Height="26" MinHeight="0" Padding="0"
                                                ToolTip="Expand all">
                                            <Viewbox Width="12" Height="12">
                                                <Path Style="{StaticResource BrowserIconPathStyle}"
                                                      Data="M3,4 H9 M3,8 H11 M3,12 H13"/>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <DockPanel Grid.Row="1" Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Command="{Binding ApplyExplorerSearchCommand}"
                                            Width="32" Height="28" MinHeight="0" Padding="0" Margin="6,0,0,0" ToolTip="Find files">
                                        <Viewbox Width="13" Height="13">
                                            <Path Style="{StaticResource BrowserIconPathStyle}" Data="M7,3.5 C5.1,3.5 3.5,5.1 3.5,7 C3.5,8.9 5.1,10.5 7,10.5 C8.9,10.5 10.5,8.9 10.5,7 C10.5,5.1 8.9,3.5 7,3.5 Z M9.8,9.8 L12.5,12.5"/>
                                        </Viewbox>
                                    </Button>
                                    <TextBox Text="{Binding ExplorerSearchQuery, UpdateSourceTrigger=PropertyChanged}" FontSize="11"
                                             Height="28" MinHeight="0" Padding="8,3" VerticalContentAlignment="Center"
                                             KeyDown="OnExplorerSearchKeyDown"/>
                                </DockPanel>

                                <TabControl Grid.Row="2" Margin="0">
                                    <TabItem Header="Solution">
                                        <TreeView x:Name="ExplorerTree"
                                                  ItemsSource="{Binding ExplorerRoots}"
                                                  MouseDoubleClick="OnExplorerDoubleClick"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  Margin="0,8,0,0">
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <Grid Height="22" ToolTip="{Binding FilePath}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}"
                                                                   FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                            <TreeView.ItemContainerStyle>
                                                <StaticResource ResourceKey="BrowserTreeItemStyle"/>
                                            </TreeView.ItemContainerStyle>
                                        </TreeView>
                                    </TabItem>

                                    <TabItem Header="Files">
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding FileExplorerRootPath}"
                                                       Foreground="{StaticResource MutedForeground}"
                                                       FontSize="9.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,6"/>
                                            <TreeView Grid.Row="1"
                                                      x:Name="FileExplorerTree"
                                                      ItemsSource="{Binding FileExplorerRoots}"
                                                      MouseDoubleClick="OnExplorerDoubleClick"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <TreeView.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                        <Grid Height="22" ToolTip="{Binding FilePath}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="18"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}"
                                                                       FontSize="10.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </HierarchicalDataTemplate>
                                                </TreeView.ItemTemplate>
                                                <TreeView.ItemContainerStyle>
                                                    <StaticResource ResourceKey="BrowserTreeItemStyle"/>
                                                </TreeView.ItemContainerStyle>
                                            </TreeView>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Symbols">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding SelectedSymbolsHeader}" Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                                <TreeView Grid.Row="1" ItemsSource="{Binding SymbolRoots}"
                                          MouseDoubleClick="OnSymbolsDoubleClick"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <Grid Margin="0,2" ToolTip="Double-click to add to canvas">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}"
                                                               FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding RangeText}" Foreground="{StaticResource MutedForeground}"
                                                               FontSize="9.5" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                    <TreeView.ItemContainerStyle>
                                        <StaticResource ResourceKey="BrowserTreeItemStyle"/>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Search">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Command="{Binding RefreshBoardSearchCommand}"
                                            Width="32" Height="28" MinHeight="0" Padding="0" Margin="6,0,0,0" ToolTip="Search board">
                                        <Viewbox Width="13" Height="13">
                                            <Path Style="{StaticResource BrowserIconPathStyle}" Data="M7,3.5 C5.1,3.5 3.5,5.1 3.5,7 C3.5,8.9 5.1,10.5 7,10.5 C8.9,10.5 10.5,8.9 10.5,7 C10.5,5.1 8.9,3.5 7,3.5 Z M9.8,9.8 L12.5,12.5"/>
                                        </Viewbox>
                                    </Button>
                                    <TextBox Text="{Binding BoardSearchQuery, UpdateSourceTrigger=PropertyChanged}" FontSize="11"
                                             Height="28" MinHeight="0" Padding="8,3" VerticalContentAlignment="Center"/>
                                </DockPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding BoardSearchResults}" MouseDoubleClick="OnBoardSearchDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Style="{StaticResource BrowserIconPathStyle}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontSize="10.5" Foreground="{StaticResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Detail}" FontSize="9.5" Foreground="{StaticResource MutedForeground}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                    </TabControl>

                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <Grid Grid.Column="2" Background="{StaticResource CanvasBg}">
                <canvas:CanvasViewport x:Name="CanvasViewport"
                                       Scene="{Binding Scene, Mode=TwoWay}"
                                       BackgroundMode="{Binding BackgroundMode, Mode=TwoWay}"
                                       SnapToGrid="{Binding SnapToGrid}"
                                       ConnectorsEnabled="{Binding ConnectorsEnabled}"
                                       AllowDrop="True"
                                       Drop="OnCanvasDrop"
                                       DragOver="OnCanvasDragOver"/>
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Cursor="SizeWE"
                          Background="{StaticResource SoftBorder}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelBorder}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <controls:BoardSidebar Grid.Column="4"
                                   Camera="{Binding Camera, ElementName=CanvasViewport, Mode=TwoWay}"
                                   ViewportWidth="{Binding ActualWidth, ElementName=CanvasViewport}"
                                   ViewportHeight="{Binding ActualHeight, ElementName=CanvasViewport}"/>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="Project loaded" Foreground="{StaticResource SubtleForeground}" FontSize="11"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Scene.Blocks.Count, StringFormat=Blocks: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Scene.Connections.Count, StringFormat=Connections: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding Scene.Annotations.Count, StringFormat=Notes: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="{Binding SelectedSwimLane.Name, StringFormat=Layer: {0}, TargetNullValue=Layer: --}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" Margin="24,0,0,0" VerticalAlignment="Center"/>
                <Border Grid.Column="5" Background="{StaticResource SuccessSoft}" CornerRadius="10" Padding="8,2" Margin="24,0,12,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="11"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                </Border>
                <TextBlock Grid.Column="6" Text="{Binding BackgroundMode, StringFormat=Canvas: {0}}" Foreground="{StaticResource SubtleForeground}"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>

