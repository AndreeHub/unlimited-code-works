<UserControl x:Class="ReviewScope.App.Controls.BoardSidebar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ReviewScope.App.Controls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ReviewScope.App;component/Styles/MainWindowStyles.xaml"/>
                <ResourceDictionary Source="/ReviewScope.App;component/Styles/InspectorTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1,0,0,0">
        <Grid Margin="12,10,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===================== Tabbed Inspector ===================== -->
            <Grid Grid.Row="0">
                <TabControl x:Name="InspectorTabs"
                            SelectedIndex="{Binding SelectedRightTabIndex, Mode=TwoWay}"
                            Visibility="{Binding HasBoardSelection, Converter={StaticResource BoolVis}}">

                    <!-- 1. Inspector - identity / details (per-type DataTemplate) -->
                    <TabItem Header="Inspector">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <ContentControl Content="{Binding ActiveInspector}"/>
                        </ScrollViewer>
                    </TabItem>

                    <!-- 2. Style - colors, fill, stroke, effects -->
                    <TabItem Header="Style">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <Grid>
                                <ContentControl Content="{Binding ActiveInspector}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTextBlockInspectorSelected}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource TextInspector.Style}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsShapeInspectorSelected}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource ShapeInspector.Style}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                                <TextBlock Text="Style options are not available for this selection."
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           FontSize="11" Foreground="{StaticResource MutedForeground}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Margin="20,40,20,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTextBlockInspectorSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsShapeInspectorSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- 3. Text - typography, layout, spacing -->
                    <TabItem Header="Text">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <Grid>
                                <ContentControl Content="{Binding ActiveInspector}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTextBlockInspectorSelected}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource TextInspector.Text}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsShapeInspectorSelected}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource ShapeInspector.Text}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                                <TextBlock Text="Text options are not available for this selection."
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           FontSize="11" Foreground="{StaticResource MutedForeground}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Margin="20,40,20,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTextBlockInspectorSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsShapeInspectorSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- 4. Arrange - z-order, size, position, lock -->
                    <TabItem Header="Arrange">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <Grid>
                                <ContentControl Content="{Binding ActiveInspector}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTextBlockInspectorSelected}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource TextInspector.Arrange}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsShapeInspectorSelected}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource ShapeInspector.Arrange}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                                <TextBlock Text="Arrange options are not available for this selection."
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           FontSize="11" Foreground="{StaticResource MutedForeground}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Margin="20,40,20,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTextBlockInspectorSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsShapeInspectorSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- No-selection placeholder -->
                <Grid Margin="20" VerticalAlignment="Center">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasBoardSelection}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No Selection" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource SubtleForeground}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Select a canvas item to inspect it." TextWrapping="Wrap" TextAlignment="Center" FontSize="11" Foreground="{StaticResource MutedForeground}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===================== Overview (always pinned to bottom) ===================== -->
            <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource SoftBorder}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Overview" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleForeground}" Margin="0,0,0,6"/>

                    <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Height="140" ClipToBounds="True">
                        <controls:SceneMiniMap
                            Scene="{Binding Scene}"
                            Camera="{Binding Camera, ElementName=Root, Mode=TwoWay}"
                            ViewportWidth="{Binding ViewportWidth, ElementName=Root}"
                            ViewportHeight="{Binding ViewportHeight, ElementName=Root}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                    </Border>

                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,8,0,0">
                        <Border Background="{StaticResource HoverBg}" BorderBrush="{StaticResource SoftBorder}" BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,0,3,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Scene.Blocks.Count}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                <TextBlock Text="Blocks" FontSize="9.5" Foreground="{StaticResource SubtleForeground}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource HoverBg}" BorderBrush="{StaticResource SoftBorder}" BorderThickness="1" CornerRadius="6" Padding="6" Margin="3,0,3,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Scene.Connections.Count}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                <TextBlock Text="Links" FontSize="9.5" Foreground="{StaticResource SubtleForeground}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource HoverBg}" BorderBrush="{StaticResource SoftBorder}" BorderThickness="1" CornerRadius="6" Padding="6" Margin="3,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Scene.Annotations.Count}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ForegroundBrush}"/>
                                <TextBlock Text="Notes" FontSize="9.5" Foreground="{StaticResource SubtleForeground}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
